--- server.py (patch: fix kp.timestamp AttributeError in qtcl_hyp_generateKeypair)
---
HypKeyPair is a NamedTuple with exactly 3 fields: private_key, public_key, address.
There is NO timestamp field. Accessing kp.timestamp raises AttributeError and the
RPC returns -32603 for every wallet creation request.

FIND this block (around line 5866):

    def qtcl_hyp_generateKeypair(params: dict, rpc_id: Any) -> dict:
        """RPC: qtcl_hyp_generateKeypair — HypΓ asymmetric keypair."""
        try:
            engine = _init_hlwe_engine()
            kp = engine.generate_keypair()
            return _rpc_ok(
                {
                    "private_key": kp.private_key,
                    "public_key": kp.public_key,
                    "address": kp.address,
                    "timestamp": kp.timestamp,   # ← BUG: AttributeError
                },
                rpc_id,
            )

REPLACE WITH:

    def qtcl_hyp_generateKeypair(params: dict, rpc_id: Any) -> dict:
        """RPC: qtcl_hyp_generateKeypair — HypΓ asymmetric keypair."""
        try:
            engine = _init_hlwe_engine()
            kp = engine.generate_keypair()
            # HypKeyPair = NamedTuple(private_key, public_key, address)
            # There is no timestamp field — we inject created_at ourselves.
            return _rpc_ok(
                {
                    "private_key": kp.private_key,
                    "public_key":  kp.public_key,
                    "address":     kp.address,
                    "created_at":  __import__('datetime').datetime.now(
                                       __import__('datetime').timezone.utc
                                   ).isoformat(),
                    "crypto": (
                        "HypΓ Schnorr-Γ / PSL(2,R) | "
                        "512-step walk | SHA3-256² address"
                    ),
                },
                rpc_id,
            )
